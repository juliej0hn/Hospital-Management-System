<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('../partials/head', { title: 'Error ' + statusCode, extraCss: ['/css/error.css'] }) %>

</head>
<body>
    <div class="error-page">
        <div class="error-card">
            <span class="error-icon"><%= statusCode === 404 ? '🔍' : '⚠️' %></span>
            <div class="error-code"><%= statusCode %></div>
            <div class="error-title">
                <%= statusCode === 404 ? 'Page Not Found' : 'Something Went Wrong' %>
            </div>
            <p class="error-message">
                <% if (statusCode === 404) { %>
                    The page you are looking for doesn't exist or has been moved.
                    Please check the URL or navigate back to safety.
                <% } else { %>
                    An unexpected error occurred on our end. Please try again later
                    or contact support if the problem persists.
                    <% if (typeof errorDetail !== 'undefined' && errorDetail) { %>
                        <br><br><small class="error-detail-text"><%= errorDetail %></small>
                    <% } %>
                <% } %>
            </p>
            <div class="error-actions">
                <a href="/" class="btn-error-home">← Go Home</a>
                <a href="javascript:history.back()" class="btn-error-back">Go Back</a>
            </div>
        </div>
    </div>
</body>
</html>
