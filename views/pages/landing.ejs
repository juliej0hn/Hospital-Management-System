<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('../partials/head', { title: 'Efficient Healthcare, Organized for You', extraCss: ['/css/landing.css'] }) %>
</head>
<body>

    <%- include('../partials/navbar', { role: 'landing' }) %>

    <main class="page-top">

        <!-- HERO -->
        <section id="hero" class="hero">
            <div class="blob blob-1"></div>
            <div class="blob blob-2"></div>
            <div class="hero-inner">
                <div class="hero-image-wrap">
                    <img src="/images/IMG_0480.PNG" alt="Hospital Management Dashboard" class="hero-image">
                </div>
                <div class="hero-content">
                    <h1>Efficient Healthcare,<br>Organized for You.</h1>
                    <p>Book appointments, manage doctors, and reduce waiting times — all in one place.</p>
                    <button class="btn-primary"
                        onclick="document.getElementById('features').scrollIntoView({behavior:'smooth'})">
                        Explore Features
                    </button>
                </div>
            </div>
        </section>

        <!-- FEATURES -->
        <section id="features" class="section">
            <h2 class="section-title">Built for Modern Healthcare</h2>
            <div class="features-grid">
                <div class="card">
                    <h3>For Patients</h3>
                    <ul class="feature-list">
                        <li><strong>Doctor Discovery:</strong> Browse doctors by specialty instantly.</li>
                        <li><strong>Sector Filter:</strong> Find Cardiology, Pediatrics, General, or Orthopedics.</li>
                        <li><strong>Simple Booking:</strong> Pick a doctor and book in seconds.</li>
                        <li><strong>Queue Position:</strong> Know exactly where you are in line.</li>
                        <li><strong>Appointment Types:</strong> Consultation, Follow-up, or Lab Result.</li>
                    </ul>
                </div>
                <div class="card">
                    <h3>For Administrators</h3>
                    <ul class="feature-list">
                        <li><strong>Doctor Setup:</strong> Add doctors with sector, time slot, and capacity.</li>
                        <li><strong>Edit Anytime:</strong> Update availability or capacity with one click.</li>
                        <li><strong>Live Dashboard:</strong> See bookings and patient names in real time.</li>
                        <li><strong>Capacity Guard:</strong> Doctors are automatically marked "Fully Booked".</li>
                        <li><strong>Sector Management:</strong> Organize doctors by medical specialty.</li>
                    </ul>
                </div>
                <div class="card">
                    <h3>For Doctors</h3>
                    <ul class="feature-list">
                        <li><strong>Personal Portal:</strong> Private access to your daily queue.</li>
                        <li><strong>Slot Control:</strong> Adjust your hours directly from your dashboard.</li>
                        <li><strong>Patient History:</strong> Review medical history before every visit.</li>
                        <li><strong>Auto-Notifications:</strong> Patients are updated via Email instantly.</li>
                    </ul>
                </div>
            </div>
        </section>

        <!-- ABOUT -->
        <section id="about" class="section">
            <div class="card about-card">
                <h2 class="section-title">About Hayat Hospital</h2>
                <p>Hayat Hospital was built on a simple idea — healthcare should be organized, not chaotic.</p>
                <p>We connect patients and doctors through smart scheduling so no one waits in a crowded lobby.</p>
            </div>
        </section>

    </main>

    <%- include('../partials/scripts', { extraScripts: ['/js/landing.js'] }) %>

</body>
</html>
