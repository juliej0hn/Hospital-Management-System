<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('../partials/head', { title: 'Admin Login', extraCss: ['/css/admin-login.css'] }) %>

</head>
<body>

    <%- include('../partials/navbar', { role: 'auth' }) %>

    <div class="app-wrap">
        <div class="admin-login-wrap">
            <div class="auth-card card admin-login-card">
                <div class="admin-login-header">
                    <span>🛡️</span>
                    <h2>Admin Portal</h2>
                    <p class="hint">Restricted access — authorized personnel only</p>
                </div>

                <% if (typeof error !== 'undefined' && error) { %>
                <div class="admin-error-box">
                    <%= error %>
                </div>
                <% } %>

                <form method="POST" action="/admin/login">
                    <div class="input-group">
                        <input type="text" name="username" placeholder="Username" required>
                    </div>
                    <div class="input-group">
                        <input type="password" name="password" placeholder="Password" required>
                    </div>
                    <button type="submit" class="btn-form">Login as Admin</button>
                </form>

                <p class="back-link-box">
                    <a href="/" class="back-link">← Back to Site</a>
                </p>
            </div>
        </div>
    </div>

    <%- include('../partials/scripts', { extraScripts: [] }) %>

</body>
</html>
