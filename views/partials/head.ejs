<%- /* Hayat Hospital — views/partials/head.ejs
     Include this at the top of every page.
     Pass: title (string), extraCss (optional array of paths)
*/ -%>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title><%= title %> — Hayat Hospital</title>
<meta name="description" content="Hayat Hospital — Efficient Healthcare, Organized for You.">

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet">

<link rel="stylesheet" href="/css/base.css">
<link rel="stylesheet" href="/css/navbar.css">
<link rel="stylesheet" href="/css/components.css">
<% if (typeof extraCss !== 'undefined') { extraCss.forEach(function(href){ %>
<link rel="stylesheet" href="<%= href %>">
<% }); } %>
